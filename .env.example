APP_NAME=
DATABASE_URL=
# 실전: https://openapi.koreainvestment.com:9443
# 모의: https://openapivts.koreainvestment.com:29443
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_APP_KEY_2=
KIS_APP_SECRET_2=
KIS_CUSTOMER_TYPE=P
KIS_TOKEN_PATH=/oauth2/tokenP
KIS_ACCESS_TOKEN=
KIS_ACCESS_TOKEN_EXPIRES_AT=
KIS_ACCESS_TOKEN_2=
KIS_ACCESS_TOKEN_EXPIRES_AT_2=
KIS_TOKEN_CACHE_ENV_FILE=.env

# 한국투자증권 순위 API 기본값은 공식 문서 기준으로 설정되어 있습니다.
KIS_VOLUME_TOP_PATH=/uapi/domestic-stock/v1/quotations/volume-rank
KIS_VOLUME_TOP_TR_ID=FHPST01710000
KIS_VOLUME_TOP_PARAMS={}
KIS_TRADE_AMOUNT_TOP_PARAMS={}
KIS_RISERS_PATH=/uapi/domestic-stock/v1/ranking/fluctuation
KIS_RISERS_TR_ID=FHPST01700000
KIS_RISERS_PARAMS={}
KIS_FALLERS_PATH=/uapi/domestic-stock/v1/ranking/fluctuation
KIS_FALLERS_TR_ID=FHPST01700000
KIS_FALLERS_PARAMS={}
KIS_HTS_TOP_VIEW_PATH=/uapi/domestic-stock/v1/ranking/hts-top-view
KIS_HTS_TOP_VIEW_TR_ID=HHMCM000100C0
KIS_INQUIRE_PRICE_PATH=/uapi/domestic-stock/v1/quotations/inquire-price
KIS_INQUIRE_PRICE_TR_ID=FHKST01010100
KIS_INQUIRE_PRICE_MARKET_DIV_CODE=UN
KIS_DAILY_ITEMCHART_PRICE_PATH=/uapi/domestic-stock/v1/quotations/inquire-daily-itemchartprice
KIS_DAILY_ITEMCHART_PRICE_TR_ID=FHKST03010100
KIS_DAILY_ITEMCHART_PRICE_MARKET_DIV_CODE=UN
KIS_DAILY_ITEMCHART_PRICE_PERIOD_DIV_CODE=D
KIS_DAILY_ITEMCHART_PRICE_ORG_ADJ_PRC=0
KIS_INDEX_PRICE_PATH=/uapi/domestic-stock/v1/quotations/inquire-index-price
KIS_INDEX_PRICE_TR_ID=FHPUP02100000
KIS_INDEX_PRICE_MARKET_DIV_CODE=U
KIS_INDEX_CODES={}

DEFAULT_TOP_N=20
KIS_TIMEOUT_SECONDS=10
KIS_REQUEST_INTERVAL_SECONDS=1
MARKET_SNAPSHOT_INTERVAL_MINUTES=30

# 실계정 KIS API를 호출하는 통합 테스트는 이 값을 1로 둔 경우에만 실행됩니다.
RUN_KIS_INTEGRATION_TESTS=0
